# Variáveis de ambiente para login via Microsoft/Outlook (OAuth 2.0)
# Copie este arquivo para .env e preencha com as credenciais do seu App Registration no Azure.
# O sistema sobe normalmente sem essas variáveis — apenas o login Microsoft ficará indisponível.

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
