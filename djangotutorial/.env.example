# =============================================================================
# IBMEC Estágios — variáveis de ambiente do backend Django
# -----------------------------------------------------------------------------
# Copie este arquivo para .env (na mesma pasta de manage.py, ou seja,
# djangotutorial/.env) e ajuste os valores. O settings.py carrega o .env
# automaticamente via python-dotenv. Variáveis sem valor padrão ficam vazias
# e o app continua subindo (ver comentários por bloco abaixo).
# =============================================================================

# ── Django (obrigatório em produção) ─────────────────────────────────────────
# Em dev, basta deixar como abaixo. Em produção, GERE uma chave aleatória com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-only-insecure-key-change-in-production

# True ou False (string literal). Em produção: False.
# Quando DEBUG=False, ALLOWED_HOSTS fica vazio — defina explicitamente no
# settings.py antes de subir para produção.
DJANGO_DEBUG=True


# ── Microsoft OAuth (opcional) ───────────────────────────────────────────────
# Carcaça do django-allauth já instalada. Sem essas variáveis, o app sobe
# normalmente; o fluxo de login Microsoft fica não-funcional, mas o login
# por email/senha continua disponível.
# Crie um App Registration no portal Azure (Azure Active Directory →
# App registrations → New registration) e copie os valores abaixo.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common


# ── Email — esqueci-senha + cadastro de empresa por aluno ────────────────────
# Em dev, mantenha EMAIL_BACKEND como 'console' para que os emails caiam no
# terminal do runserver e você consiga inspecionar os links de reset de senha
# e os emails de boas-vindas aos supervisores cadastrados via aluno.
#
# Em produção (ex.: Gmail SMTP), troque por:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# e preencha host/porta/usuário/senha do servidor SMTP.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ibmec.edu.br


# ── Frontend ──────────────────────────────────────────────────────────────────
# URL base do SPA (sem barra final). Usada para montar links absolutos em
# emails — por exemplo, o link de redefinição de senha:
#   {FRONTEND_BASE_URL}/redefinir-senha/?uid=...&token=...
# Em dev local, o SPA é servido pelo próprio Django em /dashboard-ibmec.html,
# então pode apontar para o próprio runserver.
FRONTEND_BASE_URL=http://localhost:8000
